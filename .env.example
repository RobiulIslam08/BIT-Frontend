# ============================================
# BIT SOFTWARE — ENV EXAMPLE
# ============================================
# এই ফাইলটি copy করে .env নামে save করুন
# এবং নিজের মতো করে value পরিবর্তন করুন।
# .env ফাইল .gitignore-এ আছে, git-এ push হবে না।

# Express.js Backend API URL
VITE_API_URL=http://localhost:5000/api

# Frontend URL
VITE_APP_URL=http://localhost:5173

# Google OAuth Client ID (optional)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Facebook App ID (optional)
VITE_FB_APP_ID=your_fb_app_id_here

# Google Analytics ID (optional)
VITE_GA_ID=G-XXXXXXXXXX
